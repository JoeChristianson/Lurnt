# MySQL Docker Container Configuration (for docker-compose)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=lurnt
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_PORT=3308

# Database Connection String
DATABASE_URL=mysql://user:password@localhost:3308/lurnt

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Verification
EMAIL_PROVIDER=
EMAIL_FROM=
RESEND_API_KEY=
APP_URL=http://localhost:3000

# Seed User (optional - defaults used if not set)
BOT_EMAIL=dev@example.com
BOT_USERNAME=dev
BOT_PASSWORD=password123

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Anthropic API (for conversational intake)
ANTHROPIC_API_KEY=
